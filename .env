# Copier ce fichier en .env.prod sur le serveur :
#   cp .env.prod.template .env.prod
#
# La version déployée est passée en argument à scripts/deploy.sh :
#   ./scripts/deploy.sh 1.0.0

# --- Application ---
CORS_ORIGIN=https://rocktom.armandcolin.fr
JWT_SECRET=change-me-to-a-long-random-secret

# --- Base de données ---
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=rocktom

# --- Mailer ---
MAILER_MODE=local
MAILER_FROM="Rocktom <noreply@rocktom.armandcolin.fr>"

# SMTP (uniquement si MAILER_MODE=smtp)
# MAILER_HOST=smtp.example.com
# MAILER_PORT=587
# MAILER_USER=
# MAILER_PASS=
# MAILER_SECURE=false

# --- Ports exposés sur le serveur (optionnel) ---
# API_PORT=3000
# FRONT_PORT=80
